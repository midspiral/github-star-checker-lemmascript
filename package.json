{
  "name": "github-star-checker-lemmascript",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "stars": "./bin/stars"
  },
  "scripts": {
    "stars": "npx tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "gen": "npx tsx ../LemmaScript/tools/src/lsc.ts gen --backend=dafny src/domain.ts",
    "check": "npx tsx ../LemmaScript/tools/src/lsc.ts check --backend=dafny src/domain.ts",
    "regen": "npx tsx ../LemmaScript/tools/src/lsc.ts regen --backend=dafny src/domain.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
